
        body{
            font-family: Arial, sans-serif;
            background-color:#f2f2f2;
            display:flex
        }

        .card{
            width:350px;
            margin: auto;
            padding:120px;
            border:2px solid black;
            border-radius:10px;
            text-align:left;
            background-color: lightsteelblue ;
            box-shadow:0 0 10px gray;
            
        }

        h2{
            color:blueviolet;
        }

        p{
            font-size:18px;
            color:brown;
        }

        button{
            padding:10px 20px;
            font-size:16px;
            background-color:blue;
            color:white;
            border:none;
            border-radius:5px;
            cursor:pointer;
        }

        button:hover{
            background-color:darkblue;
        }

        #message{
            margin-top:15px;
            font-size:20px;
            font-weight:bold;
            color:red;
        }
    
