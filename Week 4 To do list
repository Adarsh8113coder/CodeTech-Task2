<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Week-4 Lab Programs</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f8f9fa;
        }

        .container {
            margin-top: 30px;
        }

        .card {
            margin-bottom: 20px;
        }

        li {
            margin-top: 8px;
        }
    </style>
</head>
<body>

<div class="container">

    <h1 class="text-center mb-4">Week-4 Lab Programs</h1>

   
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h3>To-Do List App</h3>
        </div>

        <div class="card-body">

            <input type="text" id="task" class="form-control" placeholder="Enter a task">

            <br>

            <button class="btn btn-success" onclick="addTask()">
                Add Task
            </button>

            <ul id="taskList" class="mt-3"></ul>

        </div>
    </div>

    <div class="card">

        <div class="card-header bg-success text-white">
            <h3>Fetch Data from API</h3>
        </div>

        <div class="card-body">

            <button class="btn btn-primary" onclick="loadUsers()">
                Load Users
            </button>

            <div id="users" class="mt-3"></div>

        </div>

    </div>

</div>

<script>


function addTask(){

    let task = document.getElementById("task").value;

    if(task==""){
        alert("Please enter a task.");
        return;
    }

    let li=document.createElement("li");
    li.innerHTML=task;

    document.getElementById("taskList").appendChild(li);

    document.getElementById("task").value="";
}



function loadUsers(){

fetch("https://jsonplaceholder.typicode.com/users")

.then(response => response.json())

.then(data => {

let output="";

data.forEach(function(user){

output += `
<div class="card mt-2">
<div class="card-body">
<b>Name:</b> ${user.name}<br>
<b>Email:</b> ${user.email}<br>
<b>City:</b> ${user.address.city}
</div>
</div>
`;

});

document.getElementById("users").innerHTML=output;

});

}

</script>

</body>
</html>
