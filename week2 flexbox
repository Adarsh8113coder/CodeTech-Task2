<!DOCTYPE html>
<html>
<head>
    <title>Flexbox and Grid Example</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background: #f4f4f4;
        }

        h1 {
            text-align: center;
        }

        /* Flexbox */
        .flex-container {
            display: flex;
            justify-content: space-around;
            background: lightblue;
            padding: 20px;
            margin-bottom: 30px;
        }

        .flex-item {
            background: steelblue;
            color: white;
            padding: 20px;
            width: 100px;
            text-align: center;
        }

        /* Grid */
        .grid-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            background: lightgray;
            padding: 20px;
        }

        .grid-item {
            background: green;
            color: white;
            padding: 20px;
            text-align: center;
        }
    </style>
</head>

<body>

<h1>Flexbox and Grid Layout</h1>

<h2>Flexbox Example</h2>

<div class="flex-container">
    <div class="flex-item">Box 1</div>
    <div class="flex-item">Box 2</div>
    <div class="flex-item">Box 3</div>
</div>

<h2>Grid Example</h2>

<div class="grid-container">
    <div class="grid-item">1</div>
    <div class="grid-item">2</div>
    <div class="grid-item">3</div>
    <div class="grid-item">4</div>
    <div class="grid-item">5</div>
    <div class="grid-item">6</div>
</div>

</body>
</html>
